# ─── Server ───────────────────────────────────────────
PORT=5051
ENV=development
LOG_LEVEL=info
WORKERS=1

# ─── Auth ─────────────────────────────────────────────
# Shared with the rest of the platform — same token verifies inbound
# requests from Aggregation. SERVICE_AUTH_TOKEN wins; the other two
# are read as fallbacks (mirrors Enrichment-Service's resolution order).
SERVICE_AUTH_TOKEN=your-shared-service-token
MEDIA_SERVICE_TOKEN=
CMS_SERVICE_TOKEN=your-cms-service-token
CMS_BASE_URL=http://localhost:8080

# ─── Models ───────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
CLIP_MODEL=clip-ViT-B-32
MODELS_DIR=./models

# ─── Media handling ───────────────────────────────────
# Where the API spools uploaded audio/image files. The arq worker
# must be able to read from this path (shared volume in containerized
# deploys; same filesystem in dev).
MEDIA_TEMP_DIR=
MAX_UPLOAD_MB=200

# ─── Circuit Breaker (CMS write-back) ─────────────────
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_SEC=30
CB_HALF_OPEN_REQUESTS=3

# ─── Timeouts ────────────────────────────────────────
TRANSCRIBE_TIMEOUT_SEC=600
CMS_REQUEST_TIMEOUT_SEC=10

# ─── Redis (arq job queue) ───────────────────────────
# Shared Redis instance with logical DB isolation.
#   db=0 → Aggregation BullMQ
#   db=1 → Enrichment LLM cache
#   db=2 → Media arq job queue (this service)
REDIS_URL=redis://localhost:6379
ARQ_REDIS_DB=2

# ─── CORS ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*
